// ============================================================
//  REGRAS DE SEGURANÇA DO FIRESTORE — Portal RH
//
//  Como aplicar:
//  1. Vai à Firebase Console → o teu projeto
//  2. Build → Firestore Database → separador "Regras"
//  3. Substitui todo o conteúdo por este texto
//  4. Clica em "Publicar"
//
//  O que isto garante:
//  - Cada utilizador autenticado pode LER/CRIAR/EDITAR as suas próprias
//    empresas e tudo o que está dentro delas (funcionários, ausências,
//    configurações, backups, alertas) — e também ELIMINAR registos
//    individuais (ex.: um colaborador).
//  - ELIMINAR uma EMPRESA inteira só é permitido a ADMINISTRADORES
//    (quem estiver listado em admins/{uid}). Nem o próprio dono da empresa
//    a pode apagar — apenas editar.
//  - Quem for administrador pode ler/escrever os dados de QUALQUER
//    utilizador (necessário para a área de Administração: ver todas as
//    empresas, "entrar" nelas para dar suporte, eliminar empresas, etc.).
//  - A coleção "admins" só pode ser lida pelo próprio (para a app saber
//    "sou admin?"); a ESCRITA está sempre bloqueada via app — só é editável
//    manualmente na Firebase Console (separador Dados), por segurança, para
//    que ninguém se possa auto-promover a administrador.
//  - A coleção "lixeiraEmpresas" (backups de empresas inteiras eliminadas)
//    só é acessível por administradores.
//
//  Para tornares alguém administrador:
//  1. Firebase Console → Firestore Database → separador "Dados"
//  2. Cria uma coleção chamada "admins" (se não existir)
//  3. Cria um documento cujo ID é o UID do utilizador (vê em Authentication → Users)
//  4. Dentro do documento, adiciona um campo "email" (string) com o email da
//     pessoa — é só informativo, não é usado nas regras, mas ajuda a
//     identificar quem é quem.
// ============================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function ehAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function donoOuAdmin(userId) {
      return request.auth != null &&
             (request.auth.uid == userId || ehAdmin());
    }

    // Documento de cada utilizador (raiz dos seus dados).
    match /utilizadores/{userId} {
      allow read, write: if donoOuAdmin(userId);

      // A EMPRESA em si.
      match /empresas/{empresaId} {
        // Ler, criar e editar a empresa: o dono OU um administrador.
        allow read, create, update: if donoOuAdmin(userId);

        // ELIMINAR a empresa: SÓ administradores.
        // (Nem o dono não-admin a consegue apagar — só editar.)
        allow delete: if ehAdmin();

        // Tudo o que está DENTRO da empresa (funcionários, ausências,
        // configurações, backups, alertas...): o dono ou um administrador,
        // com acesso total, incluindo eliminar registos individuais.
        match /{document=**} {
          allow read, write: if donoOuAdmin(userId);
        }
      }
    }

    // Lista de administradores: cada um só lê o seu próprio documento (para
    // a app saber se é admin); escrita nunca é permitida via app.
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Lixeira de empresas eliminadas: só administradores.
    match /lixeiraEmpresas/{empresaId} {
      allow read, write: if ehAdmin();
    }

    // Por segurança, qualquer outro caminho não previsto é bloqueado por omissão.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
