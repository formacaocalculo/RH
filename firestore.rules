// ============================================================
//  REGRAS DE SEGURANÇA DO FIRESTORE — Portal RH
//
//  Como aplicar:
//  1. Vai à Firebase Console → o teu projeto
//  2. Build → Firestore Database → separador "Regras"
//  3. Substitui todo o conteúdo por este texto
//  4. Clica em "Publicar"
//
//  O que isto garante:
//  - Cada utilizador autenticado só pode ler/escrever os seus próprios dados
//    em utilizadores/{uid}/** (as suas empresas e tudo o que está dentro delas:
//    funcionários, ausências, configurações, backups, alertas).
//  - Quem estiver listado em admins/{uid} pode ler/escrever os dados de
//    QUALQUER utilizador (necessário para a área de Administração: ver todas
//    as empresas, "entrar" nelas para dar suporte, etc.).
//  - A coleção "admins" só pode ser lida pelo próprio (para a app saber
//    "sou admin?"); a ESCRITA está sempre bloqueada via app — só é editável
//    manualmente na Firebase Console (separador Dados), por segurança, para
//    que ninguém se possa auto-promover a administrador.
//  - A coleção "lixeiraEmpresas" (backups de empresas inteiras eliminadas)
//    só é acessível por administradores.
//
//  Para tornares alguém administrador:
//  1. Firebase Console → Firestore Database → separador "Dados"
//  2. Cria uma coleção chamada "admins" (se não existir)
//  3. Cria um documento cujo ID é o UID do utilizador (vê em Authentication → Users)
//  4. Dentro do documento, adiciona um campo "email" (string) com o email da
//     pessoa — é só informativo, não é usado nas regras, mas ajuda a
//     identificar quem é quem.
// ============================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function ehAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Documento de perfil do utilizador (utilizadores/{userId}) — guarda o
    // email para a área de Administração mostrar ao lado do UID. O próprio
    // escreve o seu; o próprio e os admins podem ler.
    match /utilizadores/{userId} {
      allow read: if request.auth != null &&
                     (request.auth.uid == userId || ehAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Dados de cada utilizador: LEITURA abrangente (o dono ou um admin podem
    // ler tudo dentro de utilizadores/{userId}/**). A ESCRITA é definida abaixo
    // por tipo de coleção, para podermos impor imutabilidade onde é preciso.
    match /utilizadores/{userId}/{document=**} {
      allow read: if request.auth != null &&
                     (request.auth.uid == userId || ehAdmin());
    }

    // Escrita do documento da empresa.
    match /utilizadores/{userId}/empresas/{empresaId} {
      allow write: if request.auth != null &&
                      (request.auth.uid == userId || ehAdmin());
    }

    // Escrita das subcoleções "normais" (funcionarios, ausencias, processamentos,
    // configuracoes, backups, alertas_dashboard, periodosTrabalho, …). Exclui as
    // coleções de registo de horas, que têm regras próprias logo abaixo.
    match /utilizadores/{userId}/empresas/{empresaId}/{colecao}/{docId} {
      allow write: if request.auth != null &&
                      (request.auth.uid == userId || ehAdmin()) &&
                      !(colecao in ['registosTempo', 'auditLog', 'eventos', 'folhasHoras', 'bancoHoras']);
    }

    // REGISTO DE HORAS — coleções APPEND-ONLY (imutáveis): uma vez criadas,
    // nunca podem ser alteradas nem apagadas. As correções fazem-se com NOVOS
    // registos (anulação + correção). É isto que garante a integridade e a
    // auditoria do histórico de horas.
    match /utilizadores/{userId}/empresas/{empresaId}/registosTempo/{id} {
      allow create: if request.auth != null && (request.auth.uid == userId || ehAdmin());
      allow update, delete: if false;
    }
    match /utilizadores/{userId}/empresas/{empresaId}/auditLog/{id} {
      allow create: if request.auth != null && (request.auth.uid == userId || ehAdmin());
      allow update, delete: if false;
    }
    match /utilizadores/{userId}/empresas/{empresaId}/eventos/{id} {
      allow create: if request.auth != null && (request.auth.uid == userId || ehAdmin());
      allow update, delete: if false;
    }
    // Banco de horas — movimentos APPEND-ONLY (créditos e débitos). O saldo é a
    // soma dos movimentos; correções fazem-se com novos movimentos.
    match /utilizadores/{userId}/empresas/{empresaId}/bancoHoras/{id} {
      allow create: if request.auth != null && (request.auth.uid == userId || ehAdmin());
      allow update, delete: if false;
    }

    // FOLHA DE HORAS — máquina de estados: pode ser criada e atualizada, mas o
    // estado só pode AVANÇAR (estadoOrdem nunca diminui) e nunca pode ser apagada.
    match /utilizadores/{userId}/empresas/{empresaId}/folhasHoras/{id} {
      allow create: if request.auth != null && (request.auth.uid == userId || ehAdmin());
      allow update: if request.auth != null && (request.auth.uid == userId || ehAdmin())
                    && request.resource.data.estadoOrdem >= resource.data.estadoOrdem;
      allow delete: if false;
    }

    // Collection group query usada pela área de Administração para listar
    // TODAS as empresas de todos os utilizadores (collectionGroup('empresas')).
    // A regra acima só autoriza leituras DENTRO de um utilizador específico;
    // consultas de grupo entre utilizadores precisam desta regra dedicada,
    // com o wildcard recursivo {caminho=**}. Sem isto, a área de admin recebe
    // "permission-denied" ao abrir. Restrita a administradores.
    match /{caminho=**}/empresas/{empresaId} {
      allow read: if ehAdmin();
    }

    // Lista de administradores: qualquer utilizador autenticado pode LER o
    // seu próprio documento (para saber se é admin); escrita nunca é
    // permitida via app.
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Lixeira de empresas eliminadas: só administradores.
    match /lixeiraEmpresas/{empresaId} {
      allow read, write: if ehAdmin();
    }

    // Por segurança, qualquer outro caminho não previsto é bloqueado por omissão.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
